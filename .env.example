# Copy this file to .env (local dev), .env.development, or .env.production
# and fill in real values. This file itself contains no secrets and is safe
# to commit — it documents which variables the app requires.

NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Comma-separated list of allowed origins, or * for all (never use * in production)
CORS_ORIGIN=http://localhost:3000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nest-jwt?retryWrites=true&w=majority

# Generate strong secrets, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-characters-long
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-to-a-different-random-string-at-least-32-chars
JWT_REFRESH_EXPIRATION=7d

BCRYPT_SALT_ROUNDS=12

# Rate limiting: THROTTLE_LIMIT requests per THROTTLE_TTL seconds, per IP
THROTTLE_TTL=60
THROTTLE_LIMIT=20

RESET_PASSWORD_TOKEN_EXPIRATION_MINUTES=15
EMAIL_VERIFICATION_TOKEN_EXPIRATION_HOURS=24

ACCOUNT_LOCK_MAX_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15

FRONTEND_URL=http://localhost:5173

# Optional - only needed once a real mail provider is wired up (Step 10)
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@example.com
